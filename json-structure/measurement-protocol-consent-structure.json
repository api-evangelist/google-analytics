{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/google-analytics/refs/heads/main/json-structure/measurement-protocol-consent-structure.json",
  "name": "Consent",
  "description": "Consent schema from Google Analytics API",
  "type": "object",
  "properties": {
    "ad_user_data": {
      "type": "string",
      "description": "Consent for using user data in advertising.",
      "enum": [
        "GRANTED",
        "DENIED"
      ],
      "example": "GRANTED"
    },
    "ad_personalization": {
      "type": "string",
      "description": "Consent for ad personalization.",
      "enum": [
        "GRANTED",
        "DENIED"
      ],
      "example": "GRANTED"
    }
  }
}